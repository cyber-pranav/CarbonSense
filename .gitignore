# CarbonSense — .gitignore

# Dependencies
node_modules/

# macOS metadata
.DS_Store
.AppleDouble
.LSOverride

# Environment / secrets — NEVER commit API keys
.env
.env.local
.env.*.local

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini

# Build artifacts (not expected in this zero-build project, included for safety)
dist/
build/
